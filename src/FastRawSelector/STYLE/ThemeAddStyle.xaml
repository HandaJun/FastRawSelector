<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!--
      앱 공용 테마 토큰. Common.ApplyTheme 이 Light/Dark 에 맞게 색을 덮어쓴다.
      기본값은 Dark. DynamicResource 로 참조하면 테마 전환 시 자동 반영.
    -->
    <SolidColorBrush x:Key="AppChromeBorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="AppTitleIconBrush" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="AppPanelBorderBrush" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#183F51B5"/>
    <SolidColorBrush x:Key="AppGridItemBgBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="AppGridItemBorderBrush" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="AppSplitterBrush" Color="#44FFFFFF"/>
    <SolidColorBrush x:Key="AppDropZoneBrush" Color="#330097A7"/>
    <SolidColorBrush x:Key="AppAccentBrush" Color="#0097A7"/>
    <SolidColorBrush x:Key="AppOnAccentBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#9E9E9E"/>
    <!-- 툴바/네비 아이콘 (테마 따라 밝기 반전) -->
    <SolidColorBrush x:Key="AppIconBrush" Color="#EEEEEE"/>
    <!-- 비활성 뷰 전환 아이콘 (일반 용도) -->
    <SolidColorBrush x:Key="AppMutedIconBrush" Color="#9E9E9E"/>
    <!-- 그리드/일반/전체화면 토글: 선택=메인 액센트, 비선택=회색 -->
    <SolidColorBrush x:Key="AppViewActiveBrush" Color="#0097A7"/>
    <SolidColorBrush x:Key="AppViewInactiveBrush" Color="#9E9E9E"/>
    <!-- 사진 위 오버레이(EXIF 패널) — 테마와 무관하게 어두운 유리 + 밝은 글자 -->
    <SolidColorBrush x:Key="AppPhotoOverlayBgBrush" Color="#99000000"/>
    <SolidColorBrush x:Key="AppPhotoOverlayFgBrush" Color="#FFFFFFFF"/>
    <!-- EXIF 버튼 아이콘: 라이트=어두운색, 다크=밝은색 -->
    <SolidColorBrush x:Key="AppExifIconBrush" Color="#FFFFFFFF"/>
    <!-- 하단 중앙 파일명/카운트 — 테마 무관 항상 흰색 -->
    <SolidColorBrush x:Key="AppBottomLabelBrush" Color="#FFFFFFFF"/>
    <!-- 선택됨: 사진 뒤 배경 틴트 -->
    <SolidColorBrush x:Key="AppSelectedOverlayBrush" Color="#330097A7"/>
    <!-- 그리드 칸 선택 배경 (아주 살짝) -->
    <SolidColorBrush x:Key="AppSelectedItemBgBrush" Color="#330097A7"/>

    <!-- MD 기본 썸(~18px) 대신 작은 원형 썸(10px). 그리드 크기 슬라이더 등 -->
    <ControlTemplate x:Key="AppCompactSliderThumb" TargetType="{x:Type Thumb}">
        <Grid Width="14" Height="14" Background="Transparent">
            <Ellipse Width="10" Height="10"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Fill="{TemplateBinding Foreground}"/>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="AppCompactSliderHorizontal" TargetType="{x:Type Slider}">
        <Grid VerticalAlignment="Center" Height="16" SnapsToDevicePixels="True">
            <!-- 비활성 트랙 -->
            <Border Height="2" CornerRadius="1" VerticalAlignment="Center"
                    Background="{TemplateBinding Foreground}" Opacity="0.35"/>
            <!-- 활성 트랙 (왼쪽~썸) -->
            <Border Height="2" CornerRadius="1,0,0,1" VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Background="{TemplateBinding Foreground}"
                    Width="{Binding DecreaseRepeatButton.ActualWidth, ElementName=PART_Track}"/>
            <Track x:Name="PART_Track" Height="16">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                  Style="{StaticResource MaterialDesignRepeatButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                  Style="{StaticResource MaterialDesignRepeatButton}"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Foreground="{TemplateBinding Foreground}"
                           Template="{StaticResource AppCompactSliderThumb}"/>
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style x:Key="AppCompactSlider" TargetType="{x:Type Slider}"
           BasedOn="{StaticResource MaterialDesignSlider}">
        <Setter Property="Height" Value="16"/>
        <Setter Property="MinHeight" Value="16"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template" Value="{StaticResource AppCompactSliderHorizontal}"/>
    </Style>

    <!-- 버튼 글자 Bold (MD 기본 스타일 위에 FontWeight 만 덮어씀) -->
    <Style x:Key="MaterialDesignRaisedButton" TargetType="{x:Type Button}"
           BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="MaterialDesignFlatButton" TargetType="{x:Type Button}"
           BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="MaterialDesignOutlinedButton" TargetType="{x:Type Button}"
           BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

</ResourceDictionary>
