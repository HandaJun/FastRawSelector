<UserControl x:Class="FastRawSelector.CONTROL.GridItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="180" d:DesignWidth="160"
             Width="160" Height="180"
             Cursor="Hand"
             MouseLeftButtonUp="UserControl_MouseLeftButtonUp"
             MouseDoubleClick="UserControl_MouseDoubleClick">
    <Border x:Name="RootBd" BorderBrush="{DynamicResource AppGridItemBorderBrush}" BorderThickness="2" CornerRadius="4"
            Background="{DynamicResource AppGridItemBgBrush}" Margin="3" Padding="3">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Image x:Name="ThumbImg" Stretch="Uniform" Margin="1"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   RenderOptions.EdgeMode="Unspecified"/>
            <TextBlock x:Name="PlaceholderTb" Text="…" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0.5" FontSize="22"
                       Foreground="{DynamicResource MaterialDesignBody}"/>
            <Border x:Name="SelectedMark" Width="16" Height="16" CornerRadius="8"
                    Background="{DynamicResource AppAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,3,3,0" Visibility="Collapsed"/>
            <TextBlock x:Name="FileNameTb" Grid.Row="1" TextTrimming="CharacterEllipsis"
                       FontSize="10" Margin="1,3,1,0" HorizontalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesignBody}"
                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Grid>
    </Border>
</UserControl>
