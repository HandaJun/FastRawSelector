<Window x:Class="FastRawSelector.VIEW.ExifChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="15"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="Transparent"
        mc:Ignorable="d"
        Title="{DynamicResource Loc.FileTimeTitle}" Height="560" Width="820"
        MinHeight="520" MinWidth="700"
        WindowStyle="None"
        WindowStartupLocation="Manual" Loaded="Window_Loaded" Topmost="False"
        Closing="Window_Closing" AllowsTransparency="True">
    <Border BorderBrush="{DynamicResource AppChromeBorderBrush}" BorderThickness="1" Background="{DynamicResource MaterialDesignPaper}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="#01000000" MouseDown="TitleGrid_MouseDown">
                <Image Source="/FastRawSelector;component/FastRawSelector.ico"
                       VerticalAlignment="Center" HorizontalAlignment="Left" Margin="13"/>
                <TextBlock Text="{DynamicResource Loc.FileTimeTitleFull}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="47,0"/>
                <Button Click="CloseBt_Click"
                        Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Right" Height="50"
                        Foreground="{DynamicResource AppTitleIconBrush}">
                    <Button.Content>
                        <iconPacks:PackIconBoxIcons Kind="RegularX"
                                        Width="18" Height="18" Foreground="{DynamicResource AppTitleIconBrush}"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button.Content>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="16,8,16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{DynamicResource Loc.FileTimeTarget}" VerticalAlignment="Center"/>
                        <ComboBox x:Name="SourceTargetCb" Grid.Column="1" SelectedIndex="0"
                                  Style="{StaticResource MaterialDesignComboBox}"
                                  SelectionChanged="SourceTargetCb_SelectionChanged">
                            <ComboBoxItem x:Name="AllCbi" Content="{DynamicResource Loc.DivisionCurrentAll}" Tag="All"/>
                            <ComboBoxItem x:Name="SelectedCbi" Content="{DynamicResource Loc.DivisionSelected}" Tag="Selected"/>
                            <ComboBoxItem x:Name="SpecifiedCbi" Content="{DynamicResource Loc.DivisionSpecified}" Tag="SpecifiedFolder"/>
                        </ComboBox>

                        <TextBlock Text="{DynamicResource Loc.FileTimeSource}" Grid.Row="1" VerticalAlignment="Center"/>
                        <Grid Grid.Row="1" Grid.Column="1">
                            <TextBox x:Name="SourcePathTb" Height="28" Margin="0,0,70,0" IsEnabled="False"
                                     TextChanged="TextBox_TextChanged"/>
                            <Button x:Name="SourcePathOpenBt" Content="{DynamicResource Loc.Open}" HorizontalAlignment="Right"
                                    IsEnabled="False" Click="SourcePathOpenBt_Click"
                                    Style="{StaticResource MaterialDesignRaisedButton}"/>
                        </Grid>

                        <TextBlock Text="{DynamicResource Loc.FileTimeWhich}" Grid.Row="2" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="ApplyCreatedCb" Content="{DynamicResource Loc.FileTimeCreated}" IsChecked="True" Margin="0,0,16,0"
                                      Style="{StaticResource MaterialDesignCheckBox}"/>
                            <CheckBox x:Name="ApplyModifiedCb" Content="{DynamicResource Loc.FileTimeModified}" IsChecked="True"
                                      Style="{StaticResource MaterialDesignCheckBox}"/>
                        </StackPanel>

                        <TextBlock Text="{DynamicResource Loc.FileTimeMode}" Grid.Row="3" VerticalAlignment="Top" Margin="0,10,0,0"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,6,0,0">
                            <RadioButton x:Name="ModeAbsoluteRb" Content="{DynamicResource Loc.FileTimeAbsolute}" IsChecked="True"
                                         Style="{StaticResource MaterialDesignRadioButton}"
                                         Checked="Mode_Checked" Margin="0,2"/>
                            <RadioButton x:Name="ModeOffsetRb" Content="{DynamicResource Loc.FileTimeOffset}"
                                         Style="{StaticResource MaterialDesignRadioButton}"
                                         Checked="Mode_Checked" Margin="0,2"/>
                            <RadioButton x:Name="ModeExifRb" Content="{DynamicResource Loc.FileTimeExif}"
                                         Style="{StaticResource MaterialDesignRadioButton}"
                                         Checked="Mode_Checked" Margin="0,2"/>
                        </StackPanel>

                        <StackPanel x:Name="AbsolutePanel" Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,4">
                            <DatePicker x:Name="TargetDatePicker" Width="150" Margin="0,0,12,0"/>
                            <TextBlock Text="{DynamicResource Loc.FileTimeHour}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="HourTb" Width="40" Text="12" Margin="0,0,8,0"
                                     TextAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Loc.FileTimeMinute}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="MinuteTb" Width="40" Text="0"
                                     TextAlignment="Center"/>
                        </StackPanel>
                        <StackPanel x:Name="OffsetPanel" Grid.Row="4" Grid.Column="1" Orientation="Horizontal"
                                    Margin="0,8,0,4" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource Loc.FileTimeDay}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="OffsetDaysTb" Width="50" Text="0" Margin="0,0,12,0"
                                     TextAlignment="Right"/>
                            <TextBlock Text="{DynamicResource Loc.FileTimeHours}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="OffsetHoursTb" Width="50" Text="0"
                                     TextAlignment="Right"/>
                            <TextBlock Text="{DynamicResource Loc.FileTimeNeg}" Opacity="0.6" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{DynamicResource Loc.FileTimePreviewHint}"
                               Opacity="0.75" FontSize="12" Margin="0,4,0,6" TextWrapping="Wrap"/>
                </StackPanel>

                <ListView x:Name="PreviewLv" Grid.Row="1" Margin="0,4"
                          Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource AppPanelBorderBrush}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn x:Name="ColFileGv" Header="{DynamicResource Loc.ColFile}" Width="200" DisplayMemberBinding="{Binding FileName}"/>
                            <GridViewColumn x:Name="ColBeforeGv" Header="{DynamicResource Loc.ColBefore}" Width="150" DisplayMemberBinding="{Binding BeforeModified}"/>
                            <GridViewColumn x:Name="ColAfterGv" Header="{DynamicResource Loc.ColAfter}" Width="150" DisplayMemberBinding="{Binding After}"/>
                            <GridViewColumn x:Name="ColNoteGv" Header="{DynamicResource Loc.ColNote}" Width="160" DisplayMemberBinding="{Binding Note}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <ProgressBar x:Name="ApplyPb" Grid.Row="2" Height="8" Value="0" Maximum="100"
                             Visibility="Collapsed" Margin="0,6"/>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="{DynamicResource Loc.Preview}" Width="110" Margin="0,0,10,0" Click="PreviewBt_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                    <Button x:Name="ApplyBt" Content="{DynamicResource Loc.Apply}" Width="110" Click="ApplyBt_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
