<Window x:Class="FastRawSelector.VIEW.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="15"
        Background="{DynamicResource MaterialDesignPaper}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Title="{DynamicResource Loc.SettingsTitle}"
        Height="540" Width="808"
        MinHeight="480" MinWidth="520"
        KeyDown="Window_KeyDown"
        mc:Ignorable="d">
    <Grid Margin="16,12,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingTabs"
                    Style="{StaticResource MaterialDesignTabControl}"
                    materialDesign:ColorZoneAssist.Mode="Standard">
            <TabItem x:Name="TabGeneral" Header="{DynamicResource Loc.TabGeneral}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock x:Name="BasicBehaviorTb" Text="{DynamicResource Loc.BasicBehavior}" FontSize="14" FontWeight="Medium" Margin="0,0,0,10"/>
                        <CheckBox x:Name="AlwaysOnTopCb" Content="{DynamicResource Loc.AlwaysOnTop}"
                                  Style="{StaticResource MaterialDesignCheckBox}" Margin="0,6"/>
                        <CheckBox x:Name="IsExifVisibleCb" Content="{DynamicResource Loc.ShowExif}"
                                  Style="{StaticResource MaterialDesignCheckBox}" Margin="0,6"/>
                        <CheckBox x:Name="AllowNotRawImageCb" Content="{DynamicResource Loc.AllowNonRaw}"
                                  Style="{StaticResource MaterialDesignCheckBox}" Margin="0,6"/>
                        <CheckBox x:Name="OpenLastFolderCb" Content="{DynamicResource Loc.OpenLastFolder}"
                                  Style="{StaticResource MaterialDesignCheckBox}" Margin="0,6"/>
                        <TextBlock x:Name="UpdateSectionTb" Text="{DynamicResource Loc.UpdateSection}"
                                   FontSize="14" FontWeight="Medium" Margin="0,20,0,10"/>
                        <CheckBox x:Name="AutoCheckUpdateCb" Content="{DynamicResource Loc.AutoCheckUpdate}"
                                  Style="{StaticResource MaterialDesignCheckBox}" Margin="0,6"/>
                        <Button x:Name="CheckUpdateNowBt" Content="{DynamicResource Loc.CheckUpdateNow}"
                                Margin="0,12,0,0" HorizontalAlignment="Left" Padding="16,6"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Click="CheckUpdateNowBt_Click"/>
                        <TextBlock x:Name="UpdateHintTb" Text="{DynamicResource Loc.UpdateHint}"
                                   FontSize="12" Opacity="0.7" Margin="0,10,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                        <TextBlock x:Name="LastFolderTb" FontSize="12" Opacity="0.75" Margin="0,20,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabDisplay" Header="{DynamicResource Loc.TabDisplay}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock x:Name="ThemeLabelTb" Text="{DynamicResource Loc.Theme}" FontSize="14" FontWeight="Medium" Margin="0,0,0,10"/>
                        <ComboBox x:Name="ThemeCb" Width="240" HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignComboBox}">
                            <ComboBoxItem x:Name="ThemeDarkCbi" Content="{DynamicResource Loc.ThemeDark}" Tag="Dark"/>
                            <ComboBoxItem x:Name="ThemeLightCbi" Content="{DynamicResource Loc.ThemeLight}" Tag="Light"/>
                        </ComboBox>
                        <TextBlock x:Name="ThemeHintTb" Text="{DynamicResource Loc.ThemeApplyHint}"
                                   FontSize="12" Opacity="0.7" Margin="0,12,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabHotkeys" Header="{DynamicResource Loc.TabHotkeys}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock x:Name="HotkeysTitleTb" Text="{DynamicResource Loc.HotkeysEditable}" FontSize="14" FontWeight="Medium" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="44"/>
                                <RowDefinition Height="44"/>
                                <RowDefinition Height="44"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="KeySelectLb" Text="{DynamicResource Loc.KeySelect}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="KeySelectCb" Grid.Column="1" Style="{StaticResource MaterialDesignComboBox}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="KeyExifLb" Text="{DynamicResource Loc.KeyExif}" Grid.Row="1" VerticalAlignment="Center"/>
                            <ComboBox x:Name="KeyExifCb" Grid.Row="1" Grid.Column="1" Style="{StaticResource MaterialDesignComboBox}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="KeyFullLb" Text="{DynamicResource Loc.KeyFullScreen}" Grid.Row="2" VerticalAlignment="Center"/>
                            <ComboBox x:Name="KeyFullScreenCb" Grid.Row="2" Grid.Column="1" Style="{StaticResource MaterialDesignComboBox}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="HotkeysHintTb" Text="{DynamicResource Loc.HotkeysHint}"
                                   FontSize="12" Opacity="0.7" Margin="0,16,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabExplorer" Header="{DynamicResource Loc.TabExplorer}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock x:Name="ExplorerTitleTb" Text="{DynamicResource Loc.ExplorerTitle}" FontSize="14" FontWeight="Medium" Margin="0,0,0,10"/>
                        <CheckBox x:Name="SendToCb" Content="{DynamicResource Loc.SendTo}"
                                  Style="{StaticResource MaterialDesignCheckBox}" Margin="0,6"/>
                        <CheckBox x:Name="OpenWithCb" Content="{DynamicResource Loc.OpenWith}"
                                  Style="{StaticResource MaterialDesignCheckBox}" Margin="0,6"/>
                        <TextBlock x:Name="ExplorerHintTb" Text="{DynamicResource Loc.ExplorerHint}"
                                   FontSize="12" Opacity="0.7" Margin="0,16,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabLog" Header="{DynamicResource Loc.TabLog}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock x:Name="LogLevelLb" Text="{DynamicResource Loc.LogLevel}" FontSize="14" FontWeight="Medium" Margin="0,0,0,10"/>
                        <ComboBox x:Name="LogLevelCb" Width="240" HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignComboBox}">
                            <ComboBoxItem x:Name="LogInfoCbi" Content="{DynamicResource Loc.LogInfo}" Tag="INFO"/>
                            <ComboBoxItem x:Name="LogDebugCbi" Content="{DynamicResource Loc.LogDebug}" Tag="DEBUG"/>
                        </ComboBox>
                        <TextBlock x:Name="LogHintTb" Text="{DynamicResource Loc.LogHint}"
                                   FontSize="12" Opacity="0.7" Margin="0,16,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="TabLanguage" Header="{DynamicResource Loc.TabLanguage}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,12,4,4">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock x:Name="LanguageLb" Text="{DynamicResource Loc.Language}" FontSize="14" FontWeight="Medium" Margin="0,0,0,10"/>
                        <ComboBox x:Name="LanguageCb" Width="240" HorizontalAlignment="Left"
                                  Style="{StaticResource MaterialDesignComboBox}">
                            <ComboBoxItem Content="{DynamicResource Loc.LangKo}" Tag="ko"/>
                            <ComboBoxItem Content="{DynamicResource Loc.LangJa}" Tag="ja"/>
                            <ComboBoxItem Content="{DynamicResource Loc.LangEn}" Tag="en"/>
                        </ComboBox>
                        <TextBlock x:Name="LangHintTb" Text="{DynamicResource Loc.LangHint}"
                                   FontSize="12" Opacity="0.7" Margin="0,16,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="CancelBt" Content="{DynamicResource Loc.Cancel}" Width="90" Margin="0,0,10,0" IsCancel="True"
                    Click="CancelBt_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Button x:Name="OkBt" Content="{DynamicResource Loc.OK}" Width="90" IsDefault="True"
                    Click="OkBt_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>
